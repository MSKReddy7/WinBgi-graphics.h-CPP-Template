{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build with Makefile",
      "type": "shell",
      "command": "c:\\mingw\\bin\\mingw32-make",
      "args": [
        "all"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "c:\\mingw\\bin\\mingw32-make",
      "args": [
        "clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build"
    }
  ]
}